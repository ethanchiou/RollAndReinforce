# Roblox build artifacts
*.rbxl
*.rbxlx
*.rbxm
*.rbxmx
*.rbxl.lock
*.rbxlx.lock
build.rbxlx
build.rbxl

# Wally package cache — ignore contents but keep .gitkeep so the directory
# exists on a fresh clone (default.project.json mounts it as Packages).
/Packages/*
!/Packages/.gitkeep
/ServerPackages/
/DevPackages/
wally.lock

# Rojo
sourcemap.json

# Aftman / Foreman tools (these live in user home or aftman.toml — not committed)
.aftman/
.foreman/

# Editor cruft
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Asset working files (binary, large) — opt in to LFS for what should be committed
*.blend
*.blend1
*.fbx
*.psd
*.ai
assets/raw/

# Game-ready exports under Assets/ are tracked. Working files (.blend1 autosaves,
# .psd source) stay ignored even here. Move to Git LFS when this grows past a
# few MB total.
!Assets/**/*.fbx
!Assets/**/*.blend

# Preview renders are regenerated from .blend; don't commit
Assets/**/preview-*.png

# Logs and local-only
*.log
.env
.env.local
